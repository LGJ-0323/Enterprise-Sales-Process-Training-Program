# Copy this file to .env locally, then fill in your real keys.
# Never commit .env to GitHub.

# ── API Keys ──────────────────────────────────────────
# 设为 1 时，项目 .env 会覆盖系统环境变量，避免读到旧 Key。
DOTENV_OVERRIDE=1
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ── LLM 模型 ──────────────────────────────────────────
# 推荐 qwen-plus（平衡效果与延迟），高要求场景可试 qwen-max
DASHSCOPE_LLM_MODEL=qwen-plus

# ── ASR / TTS ─────────────────────────────────────────
DASHSCOPE_ASR_MODEL=paraformer-realtime-v2
WEBRTC_ASR_USE_CALLBACK=false
DASHSCOPE_TTS_MODEL=cosyvoice-v1
DASHSCOPE_TTS_VOICE=longxiaochun

# ── ASR 识别阈值（防话没说完就被截断）───────────────
# 句尾/句中允许的静音时长(ms)，值越大越不容易截断，但回复会更慢。
WEBRTC_ASR_TRAILING_SILENCE_MS=4500
WEBRTC_ASR_MAX_SENTENCE_SILENCE_MS=4500
# Callback 模式：首次 final 超时(s)、额外等待宽限期(s)
WEBRTC_ASR_CALLBACK_FIRST_FINAL_TIMEOUT_S=12.0
WEBRTC_ASR_CALLBACK_GRACE_S=3.0
# Callback 无 final 时自动改用同步 ASR，避免“说完没反应”。
WEBRTC_ASR_SYNC_FALLBACK=true

# ── VAD 语音活动检测（2026-07-02 调整：防抢话）───────
# Silero VAD 阈值 0-1，越高越不敏感。之前 0.30 太敏感
WEBRTC_VAD_THRESHOLD=0.40
# 最短语音持续时长(ms)，白噪音短于此值被忽略
WEBRTC_MIN_SPEECH_DURATION_MS=300
# 用户静音多久判定"说完了"(ms)
WEBRTC_MIN_SILENCE_DURATION_MS=4500
# 语音前后 padding(ms)
WEBRTC_SPEECH_PAD_MS=600
# AlgoOptions 参数
WEBRTC_STARTED_TALKING_THRESHOLD=0.18
WEBRTC_SPEECH_THRESHOLD=0.12
# 最长连续说话(s)，防止长句被切断
WEBRTC_MAX_CONTINUOUS_SPEECH_S=30.0

# ── WeChat WebSocket 实时语音识别（防短噪声/幻听）────
WS_ASR_SAMPLE_RATE=16000
WS_VAD_THRESHOLD=0.018
WS_VAD_MIN_SPEECH_MS=450
WS_VAD_MIN_SILENCE_MS=1600
WS_MIN_UTTERANCE_MS=900
WS_MIN_AUDIO_RMS=0.012
WS_ASR_TRAILING_SILENCE_MS=1800
WS_ASR_MAX_SENTENCE_SILENCE_MS=1800
WS_ASR_CALLBACK_FIRST_TIMEOUT_S=8.0
WS_ASR_CALLBACK_GRACE_S=1.2

# ── App ───────────────────────────────────────────────
APP_PORT=8510
WECHAT_APP_HOST=127.0.0.1
WECHAT_APP_PORT=8511
CUSTOMER_PROFILE_PATH=

# ── Training Defaults ─────────────────────────────────
TRAINING_STAGE_ID=cold_call
TRAINING_CUSTOMER_ID=auto
TRAINING_DIFFICULTY_ID=easy
TRAINING_VOICE_ID=longsanshu_v3
TRAINING_AVATAR_ID=wang_ms_avatar
TRAINING_DB_PATH=
